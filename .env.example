# local dev (default): local Postgres + Neon HTTP proxy via `sst dev` / docker compose
DATABASE_URL=postgres://postgres:postgres@db.localtest.me:5432/main

# production: switch to a Neon connection string for `sst deploy`
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/main?sslmode=require

# optional, only used by `bun run db:seed`
# BQ_PROJECT=pypi-pro
# BQ_TABLE=pypi.packages_summary
# SEED_BUCKET=pypi-pro-seed